{
  "name": "taurus-agents",
  "version": "0.1.0",
  "type": "module",
  "description": "A generalized multi-agent orchestration framework",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "vite --config src/web/vite.config.ts",
    "build:web": "vite build --config src/web/vite.config.ts",
    "start": "node --loader tsx src/index.ts",
    "daemon": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "makemigration": "tsx node_modules/sequelize-auto-migrations/bin/makemigration.js && for f in src/db/migrations/*.js; do [ -f \"$f\" ] && mv \"$f\" \"${f%.js}.cjs\"; done",
    "migrate": "npx sequelize-cli db:migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@mozilla/readability": "^0.6.0",
    "@vscode/ripgrep": "^1.15.9",
    "croner": "^10.0.1",
    "cronstrue": "^3.13.0",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.2",
    "linkedom": "^0.18.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sequelize": "^6.37.5",
    "sequelize-auto-migrations": "github:pointnetwork/sequelize-auto-migrations#all-the-changes",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^5.1.7",
    "tree-kill": "^1.2.2",
    "turndown": "^7.2.2",
    "uuid": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "sass": "^1.97.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  }
}
