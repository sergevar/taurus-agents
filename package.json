{
  "name": "taurus-agents",
  "version": "0.1.0",
  "type": "module",
  "description": "A generalized multi-agent coding assistant",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node --loader tsx src/index.ts",
    "daemon": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "makemigration": "tsx node_modules/sequelize-auto-migrations/bin/makemigration.js && for f in src/db/migrations/*.js; do [ -f \"$f\" ] && mv \"$f\" \"${f%.js}.cjs\"; done",
    "migrate": "npx sequelize-cli db:migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@vscode/ripgrep": "^1.15.9",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.2",
    "sequelize": "^6.37.5",
    "sequelize-auto-migrations": "github:pointnetwork/sequelize-auto-migrations#all-the-changes",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^5.1.7",
    "tree-kill": "^1.2.2",
    "uuid": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
