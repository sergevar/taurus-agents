#!/usr/bin/env bash
cd "$(dirname "$0")"

case "${1:-}" in
  build)
    npx vite build --config src/web/vite.config.ts
    ;;
  watch)
    npx vite build --config src/web/vite.config.ts --watch
    ;;
  dev)
    # Build web first, then start daemon
    npx vite build --config src/web/vite.config.ts
    exec npx tsx src/index.ts "${@:2}"
    ;;
  seed)
    # Create a test agent via the API
    PORT="${2:-7777}"
    NAME="test$(curl -s "http://localhost:$PORT/api/agents" | grep -o '"name":"test[0-9]*"' | wc -l | tr -d ' ')"
    NAME="test$(($(curl -s "http://localhost:$PORT/api/agents" | grep -o '"name":"test[0-9]*"' | wc -l) + 1))"
    curl -s -X POST "http://localhost:$PORT/api/agents" \
      -H 'Content-Type: application/json' \
      -d "{
        \"name\": \"$NAME\",
        \"type\": \"actor\",
        \"system_prompt\": \"Look around the environment. List files, read a few interesting ones, and report back what you see. Be concise.\",
        \"tools\": [\"Read\", \"Glob\", \"Grep\", \"Bash\"],
        \"cwd\": \"$(pwd)\"
      }" | python3 -m json.tool 2>/dev/null || echo "Failed — is the daemon running?"
    ;;
  status)
    # Check if Taurus is running
    LOCKFILE="data/taurus.lock"
    if [ -f "$LOCKFILE" ]; then
      PID=$(grep -o '"pid":[0-9]*' "$LOCKFILE" | cut -d: -f2)
      PORT=$(grep -o '"port":[0-9]*' "$LOCKFILE" | cut -d: -f2)
      STARTED=$(grep -o '"startedAt":"[^"]*"' "$LOCKFILE" | cut -d'"' -f4)
      if kill -0 "$PID" 2>/dev/null; then
        echo "Taurus is running"
        echo "  PID: $PID"
        echo "  Port: $PORT"
        echo "  Started: $STARTED"
        exit 0
      else
        echo "Stale lockfile found (PID $PID not running)"
        exit 1
      fi
    else
      echo "Taurus is not running"
      exit 1
    fi
    ;;
  *)
    # Auto-build web UI if missing or stale
    needs_build=false
    if [ ! -d "src/web/dist" ]; then
      needs_build=true
    else
      # Rebuild if any source file is newer than the dist
      newest_src=$(find src/web/src src/web/index.html -type f -newer src/web/dist/index.html 2>/dev/null | head -1)
      if [ -n "$newest_src" ]; then
        needs_build=true
      fi
    fi
    if [ "$needs_build" = true ]; then
      echo "Building web UI..."
      npx vite build --config src/web/vite.config.ts
    fi
    exec npx tsx src/index.ts "$@"
    ;;
esac