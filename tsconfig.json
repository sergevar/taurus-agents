{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "#core/*": ["./src/core/*"],
      "#inference/*": ["./src/inference/*"],
      "#tools/*": ["./src/tools/*"],
      "#agents/*": ["./src/agents/*"],
      "#db/*": ["./src/db/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "data"]
}
